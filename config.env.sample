# rinex-recorder configuration.
# Copy to config.env and edit -- config.env is git-ignored so machine-specific
# paths never get committed (same convention as gps-base-station's config.env).

# --- NTRIP source (gps-base-station's local caster; see local_caster.hpp) ---
NTRIP_HOST=192.168.8.186
NTRIP_PORT=2101
NTRIP_MOUNTPOINT=BASE0

# --- Storage paths ---
RAW_DIR=/home/aziobro/rinex-recorder/raw
RINEX_DIR=/home/aziobro/rinex-recorder/rinex

# --- RINEX header metadata ---
# Keep in sync with the base station's own /config page (Antenna section) --
# see gps-base-station docs/agent-memory/project_rinex.md.
ANT_TYPE="HXCGPS500 NONE"
ANT_DELTA="0/0/0"
MARKER_NAME=BASE0

# --- RINEX output decimation ---
# Capture is 1Hz; convbin decimates to this on conversion. 30s matches
# gps-base-station's on-device rinex_logger.cpp (kEpochInterval) and the
# standard CORS/IGS static-observation rate. raw/ keeps the full 1Hz stream
# regardless -- this only thins the converted output.
EPOCH_INTERVAL_SEC=30

# --- Tools ---
# Full path to convbin if not on $PATH (e.g. after building RTKLIB from
# source without a `make install` step).
CONVBIN=convbin
